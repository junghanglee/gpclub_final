# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies / build output
node_modules/
dist/
dist-ssr/
.output/
.vinxi/
.tanstack/
.nitro/
*.tsbuildinfo

# Environment and secrets
.env
.env.*
!.env.example
*.local
*.pem
*.key
*token*.txt
token_key.txt

# Local platform state
.vercel/
.wrangler/
.dev.vars
supabase/.temp/

# Local agent/browser scratch files
.openclaw*
.chrome*/
.workspace/
.opencode/artifacts/playwright-*.json
.opencode/artifacts/playwright-*.png
.opencode/artifacts/run-playwright-*.cjs
*.html
!index.html
!public/downloads/*.html
snippet.txt

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Large generated source data kept out of Git
# Anchor to repo root so this never matches src/data/ (which previously made
# the Vercel build fail because src/data/* was untracked + missing on disk).
/data/
docs/generated/

# Local agent tooling state — memory DBs hold session secrets (Supabase
# PAT, service_role keys, access tokens) captured from working sessions,
# so they must never be tracked or pushed. Only non-secret state (.beads
# issue history, .zcode/state session-summary text) is committed.
.opencode/memory.db
.opencode/memory.db-shm
.opencode/memory.db-wal
.zcode/memory.db
.vercel
.env*
